# ─────────────────────────────────────────────────────────────────────────────
# AutoQA Agent — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/autoqa_agent

# CORS — comma-separated origins allowed to access the API
CORS_ORIGIN=http://localhost:5173

# Logging
# Levels: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=debug

# API
API_PREFIX=/api/v1

# Future: AI engine settings
# OPENAI_API_KEY=
# AI_MODEL=gpt-4o
